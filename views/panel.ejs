<%- include("partials/header", {title:"Kütüphane Paneli"}) %><%- include("partials/nav") %><main class="dashboard"><aside><b>Kütüphane Paneli</b><a>Ayarlar</a><a>Etkinlikler</a><a>Başvurular</a><a>Oyunlar</a><a>Arşiv</a></aside><section><h1><%= lib.name %></h1><div class="dash-grid"><div><b><%= events.length %></b><span>Aktif Etkinlik</span></div><div><b><%= games.length %></b><span>Zeka Oyunu</span></div><div><b><%= lib.score %></b><span>Puan</span></div></div><div class="panel-grid"><form class="panel-card" method="post" action="/panel/settings"><h2>Logo / Banner / Bilgi Ayarları</h2><textarea name="about"><%= lib.about %></textarea><input name="working_hours" value="<%= lib.working_hours %>"><input name="phone" value="<%= lib.phone %>"><input name="address" value="<%= lib.address %>"><label>Logo X <input type="range" name="logo_pos_x" min="0" max="100" value="<%= lib.logo_pos_x %>"></label><label>Logo Y <input type="range" name="logo_pos_y" min="0" max="100" value="<%= lib.logo_pos_y %>"></label><label>Logo Zoom <input type="range" name="logo_zoom" min="1" max="2" step="0.05" value="<%= lib.logo_zoom %>"></label><label>Banner X <input type="range" name="banner_pos_x" min="0" max="100" value="<%= lib.banner_pos_x %>"></label><label>Banner Y <input type="range" name="banner_pos_y" min="0" max="100" value="<%= lib.banner_pos_y %>"></label><button>Kaydet</button></form><form class="panel-card" method="post" action="/panel/events"><h2>Yeni Etkinlik</h2><input name="title" placeholder="Etkinlik adı" required><textarea name="description" placeholder="Açıklama"></textarea><input name="category" placeholder="Kategori"><input name="event_date" type="date" required><input name="event_time" placeholder="15:00"><input name="place" placeholder="Yer"><input name="min_age" type="number" placeholder="Min yaş"><input name="max_age" type="number" placeholder="Max yaş"><input name="capacity" type="number" placeholder="Kontenjan"><button>Etkinlik Ekle</button></form></div></section></main><%- include("partials/footer") %>

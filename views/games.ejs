<%- include("partials/header", {title: lib.name + " Oyunlar"}) %><main class="lib-page"><%- include("partials/library-nav", {lib}) %><section class="section-head"><h1>Zeka Oyunları</h1><p>Her oyun raf kodu, yaş aralığı ve müsaitlik bilgisiyle listelenir.</p></section><div class="game-list"><% games.forEach(g => { %><article class="game-card"><div>🧩</div><section><h3><%= g.name %></h3><p><%= g.description %></p><small><%= g.age_range %> • <%= g.players %> • Raf: <%= g.shelf_code %> • <%= g.available ? "Müsait" : "Kullanımda" %></small></section></article><% }) %></div></main><%- include("partials/footer") %>

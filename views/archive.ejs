<%- include("partials/header", {title: lib.name + " Arşiv"}) %><main class="lib-page"><%- include("partials/library-nav", {lib}) %><section class="section-head"><h1>Etkinlik Arşivi</h1><p>Geçmiş etkinliklerde başvuru butonu bulunmaz.</p></section><div class="event-grid"><% if (!events.length) { %><p class="empty">Henüz arşiv etkinliği yok.</p><% } %><% events.forEach(e => { %><article class="event-card"><div class="event-poster">🖼️</div><span><%= e.category %></span><h3><%= e.title %></h3><p><%= e.event_date %></p></article><% }) %></div></main><%- include("partials/footer") %>
